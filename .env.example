# ─── Agora (voice calls) ──────────────────────────────────
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
NEXT_PUBLIC_AGORA_APP_ID=

# ─── OpenRouter (AI chat) ─────────────────────────────────
OPENROUTER_API_KEY=
