rules_version = '2';

/**
 * Firestore Security Rules for ByteReaper
 * 
 * Single-document architecture:
 * - chat_session/{sessionId} — each doc holds the full conversation as a messages array
 * - archived_chats/{sessionId} — archived chats with the same structure
 * - users/{emailId} — user profiles keyed by email
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasAuthEmail() {
      return isAuthenticated() && request.auth.token.email is string;
    }

    function isEmailOwner(emailId) {
      return hasAuthEmail() && request.auth.token.email == emailId;
    }

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'belaltamerhegab@gmail.com'
          && request.auth.token.email_verified == true;
    }

    // ─── Users ─────────────────────────────────────

    match /users/{emailId} {
      allow read: if isEmailOwner(emailId) || isAdmin();
      allow create: if isEmailOwner(emailId) &&
                      request.resource.data.uid == request.auth.uid &&
                      request.resource.data.email == emailId &&
                      request.resource.data.createdAt is timestamp;
      allow update: if isEmailOwner(emailId) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.email == emailId;
      allow delete: if isEmailOwner(emailId);
    }

    // ─── Chat Sessions (single-document architecture) ──

    match /chat_session/{sessionId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid)
                     || isAdmin();

      // userEmail is optional — not all clients send it
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.title == sessionId &&
                       request.resource.data.title is string &&
                       request.resource.data.model is string &&
                       request.resource.data.messages is list &&
                       request.resource.data.isArchived is bool;

      allow update: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == resource.data.userId &&
                       request.resource.data.title is string &&
                       request.resource.data.messages is list;

      allow delete: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
    }

    // ─── Archived Chats ────────────────────────────

    match /archived_chats/{sessionId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid)
                     || isAdmin();

      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.title == sessionId;

      allow update: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.title == sessionId;

      allow delete: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
    }

    // ─── Shared Chats (public read via share links) ───────

    match /shared_chats/{shareId} {
      allow read: if resource.data.isPublic == true ||
                     (isAuthenticated() && resource.data.ownerId == request.auth.uid);

      allow create: if isAuthenticated() &&
                       request.resource.data.ownerId == request.auth.uid &&
                       request.resource.data.title is string &&
                       request.resource.data.messages is list &&
                       request.resource.data.isPublic == true;

      allow update, delete: if isAuthenticated() &&
                              resource.data.ownerId == request.auth.uid;
    }

    // ─── User Prompt Templates ────────────────────────────

    match /user_prompt_templates/{userId} {
      allow read, delete: if isOwner(userId);

      allow create, update: if isOwner(userId) &&
                               request.resource.data.userId == request.auth.uid &&
                               request.resource.data.templates is list;
    }

    // ─── User Tool Favorites (email-keyed) ──────────────────

    match /user_tool_favorites/{docId} {
      allow read, delete: if isOwner(docId) || isEmailOwner(docId) || isAdmin();

      allow create, update: if (isOwner(docId) || isEmailOwner(docId))
                               && request.resource.data.userId == request.auth.uid
                               && request.resource.data.favorites is list;
    }

    // ─── Private Chat: User Profiles ──────────────────────

    match /user_profiles/{emailId} {
      // Anyone authenticated can read profiles (for search / peer info)
      allow read: if isAuthenticated() || isAdmin();

      // Only the owner can create/update their own profile (doc keyed by email)
      allow create: if isEmailOwner(emailId) &&
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.username is string &&
                       request.resource.data.publicKey is string;

      allow update: if (isEmailOwner(emailId) || isAdmin()) &&
                       request.resource.data.uid == resource.data.uid;

      allow delete: if isEmailOwner(emailId) || isAdmin();
    }

    // ─── Private Chat: Username Reservations ──────────────

    match /usernames/{usernameLower} {
      allow read: if isAuthenticated();

      // Only the owner of the uid stored can create
      allow create: if isAuthenticated() &&
                       request.resource.data.uid == request.auth.uid;

      // Only the owner can delete their own reservation
      allow delete: if isAuthenticated() &&
                       resource.data.uid == request.auth.uid;
    }

    // ─── Private Chat: Conversations ──────────────────────

    match /conversations/{conversationId} {
      // Only participants (or admin) can read
      allow read: if (isAuthenticated() && request.auth.uid in resource.data.participants)
                     || isAdmin();

      // Creation handled by server API, but allow client-side updates for
      // wrappedKeys, typing, and unread counters
      allow update: if isAuthenticated() &&
                       request.auth.uid in resource.data.participants;

      // Participants can delete the conversation (deletes for both)
      allow delete: if isAuthenticated() &&
                       request.auth.uid in resource.data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        // Only conversation participants (or admin) can read messages
        allow read: if (isAuthenticated() &&
                       request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants)
                       || isAdmin();

        // Only conversation participants can write messages,
        // and senderId must match the authenticated user
        allow create: if isAuthenticated() &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants &&
                         request.resource.data.senderId == request.auth.uid;

        // Allow updating readBy array
        allow update: if isAuthenticated() &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;

        // Allow participants to delete messages (for conversation deletion)
        allow delete: if isAuthenticated() &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }

    // ─── Private Chat: Voice Calls ────────────────────────

    match /calls/{callId} {
      allow read: if isAuthenticated() &&
                     (resource.data.callerId == request.auth.uid ||
                      resource.data.calleeId == request.auth.uid);

      allow create: if isAuthenticated() &&
                       request.resource.data.callerId == request.auth.uid;

      allow update: if isAuthenticated() &&
                       (resource.data.callerId == request.auth.uid ||
                        resource.data.calleeId == request.auth.uid);
    }

    // ─── Messenger Profiles (uid-keyed) ──────────────────────

    match /messenger_profiles/{uid} {
      allow read:   if isAuthenticated() && request.auth.uid == uid;
      allow create: if isAuthenticated() && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.username is string
                    && request.resource.data.passwordHash is string
                    && request.resource.data.passwordSalt is string;
      allow update: if isAuthenticated() && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.username == resource.data.username;
      allow delete: if isAuthenticated() && request.auth.uid == uid;
    }

    // ─── Messenger Username Reservations ─────────────────────

    match /messenger_usernames/{usernameLower} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
                    && resource.data.uid == request.auth.uid;
    }
  }
}
