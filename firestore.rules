rules_version = '2';

/**
 * Firestore Security Rules for ByteReaper
 * 
 * These rules ensure that:
 * - Users can only access their own data
 * - All operations require authentication
 * - Data validation for critical fields
 */

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check if authenticated user has an email claim
    function hasAuthEmail() {
      return isAuthenticated() && request.auth.token.email is string;
    }

    // Helper to check if user owns an email-keyed document
    function isEmailOwner(emailId) {
      return hasAuthEmail() && request.auth.token.email == emailId;
    }

    // Helper to get a chat session document path
    function chatSessionPath(sessionId) {
      return /databases/$(database)/documents/chatSessions/$(sessionId);
    }

    // Helper to ensure a chat session belongs to current user
    function ownsSession(sessionId) {
      return exists(chatSessionPath(sessionId)) &&
             get(chatSessionPath(sessionId)).data.userId == request.auth.uid;
    }
    
    // Users collection - users can only read/write their own profile using email doc IDs
    match /users/{emailId} {
      allow read: if isEmailOwner(emailId);
      allow create: if isEmailOwner(emailId) &&
                      request.resource.data.uid == request.auth.uid &&
                      request.resource.data.email == emailId &&
                      request.resource.data.createdAt is timestamp;
      allow update: if isEmailOwner(emailId) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.email == emailId;
      allow delete: if isEmailOwner(emailId);
    }
    
    // Chat sessions - users can only access their own sessions
    match /chatSessions/{sessionId} {
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.title is string &&
                       request.resource.data.model is string;
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
    
    // Chat messages - users can only access their own messages
    match /chatMessages/{messageId} {
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.sessionId is string &&
                       ownsSession(request.resource.data.sessionId) &&
                       request.resource.data.role in ['user', 'assistant'] &&
                       request.resource.data.content is string;
      allow update: if false; // Messages should not be updated
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
  }
}
